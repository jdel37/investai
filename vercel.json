{
  "builds": [
    { "src": "main.py", "use": "@vercel/python", "config": { "maxDuration": 60 } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "main.py" }
  ],
  "crons": [
    { "path": "/api/scheduled-analysis", "schedule": "0 8 * * 1" },
    { "path": "/api/check-trigger",       "schedule": "0 9 * * *" }
  ]
}
